Host home
  HostName 10.13.13.1
  User cfanch06
  IdentityFile ~/.ssh/id_ed25519   # or your existing key path
  IdentitiesOnly yes
  ServerAliveInterval 30

  # optional speed-ups / convenience
  ControlMaster auto
  ControlPath ~/.ssh/cm-%r@%h:%p
  ControlPersist 10m
  Compression yes
