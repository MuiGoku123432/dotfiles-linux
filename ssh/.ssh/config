  # Port 2222
Host github-personal
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_ed25519
  IdentitiesOnly yes
  AddKeysToAgent yes


Host github-sentinovo
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_sentinovo
  IdentitiesOnly yes
  AddKeysToAgent yes


